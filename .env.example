# Server-side Google Maps API key
# Used by:
# - /api/geo/autocomplete (Places API (New))
# - /api/geo/verify-address (Place Details (New))
GOOGLE_MAPS_API_KEY=

# Daily Pricing admin credentials (required in production)
DAILY_PRICING_SEEDED_EMAIL=
DAILY_PRICING_SEEDED_PASSWORD=

# Optional: one-time seed endpoint token for /api/daily-pricing/seed in production.
DAILY_PRICING_SEED_TOKEN=

# Optional: writable data directory for daily-pricing.json.
# Defaults:
# - local dev: ./.data
# - Vercel/production/serverless: /tmp/stone-river-mortgage
# DAILY_PRICING_DATA_DIR=/absolute/path

# Recommended for Vercel: persistent shared Daily Pricing store via KV REST.
# Supports either explicit DAILY_PRICING_* names or Vercel KV defaults
# (KV_REST_API_URL / KV_REST_API_TOKEN).
# DAILY_PRICING_KV_REST_URL=
# DAILY_PRICING_KV_REST_TOKEN=
# Optional key override (default: stone-river-mortgage:daily-pricing:v1)
# DAILY_PRICING_KV_KEY=

# Optional: additional trusted CA bundle for county TLS chain validation.
# Use when a county endpoint (for example Carver) serves an incomplete chain.
# IMPORTANT: NODE_EXTRA_CA_CERTS must be set in the process environment
# before starting Node (export in shell or configure in deployment runtime).
# NODE_EXTRA_CA_CERTS=/absolute/path/to/extra-ca-bundle.pem

# Preferred for Vercel production Carver lookups:
# PEM certificate-chain text (not a file path). Supports escaped newlines.
# CARVER_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Optional local helper input for `npm run dev:carver`.
# The helper reads this PEM file into CARVER_CA_PEM and also sets
# NODE_EXTRA_CA_CERTS before Next starts.
# CARVER_EXTRA_CA_BUNDLE=/absolute/path/to/extra-ca-bundle.pem

# Optional override to allow default seeded daily-pricing credentials in production.
# Not recommended.
# DAILY_PRICING_ALLOW_DEFAULT_SEEDED_CREDENTIALS=false
