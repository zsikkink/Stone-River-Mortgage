# Required: server-side Google Places API key
# Used by:
# - /api/geo/autocomplete (Places API (New))
# - /api/geo/verify-address (Place Details API (New))
GOOGLE_MAPS_API_KEY=

# Required in production: Daily Pricing sign-in credentials
DAILY_PRICING_SEEDED_EMAIL=
DAILY_PRICING_SEEDED_PASSWORD=

# Optional: protect /api/daily-pricing/seed in production
# DAILY_PRICING_SEED_TOKEN=

# Optional local override for where daily-pricing.json is stored.
# Defaults:
# - local dev: ./.data
# - serverless (Vercel): /tmp/stone-river-mortgage
# DAILY_PRICING_DATA_DIR=/absolute/path

# Recommended in production: persistent shared pricing + analytics via KV REST.
# Supported aliases:
# - DAILY_PRICING_KV_REST_URL / DAILY_PRICING_KV_REST_TOKEN
# - KV_REST_API_URL / KV_REST_API_TOKEN
# - UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
DAILY_PRICING_KV_REST_URL=
DAILY_PRICING_KV_REST_TOKEN=

# Optional key overrides.
# DAILY_PRICING_KV_KEY=stone-river-mortgage:daily-pricing:v1
# DAILY_PRICING_ANALYTICS_KV_KEY=stone-river-mortgage:daily-pricing:v1:analytics

# Preferred Carver TLS fix for Vercel production:
# PEM certificate chain text (not a file path). Escaped \n is supported.
# CARVER_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Optional local helper input for `npm run dev:carver`.
# CARVER_EXTRA_CA_BUNDLE=/absolute/path/to/extra-ca-bundle.pem

# Optional startup-level CA trust extension for local/runtime shells.
# Note: NODE_EXTRA_CA_CERTS is read at Node startup only.
# NODE_EXTRA_CA_CERTS=/absolute/path/to/extra-ca-bundle.pem

# Optional diagnostic override for `npm run check:carver-tls`
# CARVER_TLS_CHECK_URL=https://publicaccess.carvercountymn.gov/search/commonsearch.aspx?mode=combined

# Optional emergency override for production login gate.
# Set true only if you intentionally want default seeded credentials in production.
# DAILY_PRICING_ALLOW_DEFAULT_SEEDED_CREDENTIALS=false
