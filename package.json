{
  "name": "stone-river-mortgage",
  "version": "0.1.0",
  "private": true,
  "description": "Stone River Mortgage website and transaction summary engine built with Next.js and TypeScript.",
  "author": "Zack Sikkink",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/zsikkink/Stone-River-Mortgage.git"
  },
  "homepage": "https://stonerivermortgage.com",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node scripts/reset-next-cache.mjs && next dev",
    "dev:carver": "node scripts/dev-carver.mjs",
    "dev:reset": "node scripts/reset-next-cache.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "verify": "npm test && npm run build && npm run typecheck",
    "test": "vitest run",
    "check:carver-tls": "node scripts/check-carver-tls.mjs"
  },
  "dependencies": {
    "next": "15.5.10",
    "pdf-lib": "^1.17.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.3",
    "vitest": "^4.0.18"
  }
}
